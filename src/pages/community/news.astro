---
import MainLayout from '../../layouts/main.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';

const pageClass = 'news-page';
---

<MainLayout pageClass={pageClass}>
  <Header client:only="react" />
  
  <section style="position: relative; height: 300px; background-image: url(https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=1600&q=80); background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center;">
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(11, 42, 111, 0.75);"></div>
    <div style="position: relative; z-index: 10; text-align: center; color: #F7F3EA; max-width: 900px; padding: 0 24px;">
      <h1 style="font-family: var(--heading-font); font-size: 56px; font-weight: 600; margin-bottom: 20px; color: #F7F3EA;">News & Stories</h1>
      <p style="font-family: var(--body-font); font-size: 22px; line-height: 1.6; color: #F7F3EA;">What's happening at St. Mark's</p>
    </div>
  </section>

  <section style="background-color: #F7F3EA; padding: 96px 24px;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div style="display: grid; gap: 48px;">
        
        <article style="background-color: #FCFBF7; padding: 48px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <div style="font-family: var(--body-font); font-size: 14px; color: #7d797a; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">March 15, 2026</div>
          <h2 style="font-family: var(--heading-font); font-size: 32px; color: #123EAB; margin-bottom: 20px; font-weight: 600;">Spring Open House Success</h2>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8; margin-bottom: 16px;">
            We had a wonderful turnout at our Spring Open House! Over 40 prospective families toured our campus, observed classroom activities, and met with our faculty and staff.
          </p>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8;">
            Highlights included student presentations in Latin, a Montessori work cycle demonstration, and a special chapel service. Thank you to everyone who joined us!
          </p>
        </article>

        <article style="background-color: #FCFBF7; padding: 48px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <div style="font-family: var(--body-font); font-size: 14px; color: #7d797a; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">March 1, 2026</div>
          <h2 style="font-family: var(--heading-font); font-size: 32px; color: #123EAB; margin-bottom: 20px; font-weight: 600;">Lenten Service Project</h2>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8; margin-bottom: 16px;">
            Our students are participating in a Lenten service project, collecting items for a local food pantry. Each week during Lent, students bring donations and learn about serving others in Christ's name.
          </p>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8;">
            This hands-on experience helps our students understand that faith is expressed through action and love for neighbor.
          </p>
        </article>

        <article style="background-color: #FCFBF7; padding: 48px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <div style="font-family: var(--body-font); font-size: 14px; color: #7d797a; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">February 10, 2026</div>
          <h2 style="font-family: var(--heading-font); font-size: 32px; color: #123EAB; margin-bottom: 20px; font-weight: 600;">Valentine's Day Family Event</h2>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8;">
            Mark your calendars! On February 14th, we're hosting a special Valentine's Day family event featuring crafts, poetry recitations, and treats. This is a wonderful opportunity for families to connect and celebrate together.
          </p>
        </article>

        <article style="background-color: #FCFBF7; padding: 48px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <div style="font-family: var(--body-font); font-size: 14px; color: #7d797a; margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">January 20, 2026</div>
          <h2 style="font-family: var(--heading-font); font-size: 32px; color: #123EAB; margin-bottom: 20px; font-weight: 600;">New Art Program Launches</h2>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8;">
            We're excited to announce the launch of our new art program! Students will explore classical art techniques, study great works from Christian tradition, and create their own masterpieces. The program emphasizes beauty, craftsmanship, and creativity as gifts from God.
          </p>
        </article>

      </div>
    </div>
  </section>

  <Footer client:only="react" />
</MainLayout>
