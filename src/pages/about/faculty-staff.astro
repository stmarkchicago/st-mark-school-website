---
import MainLayout from '../../layouts/main.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';

const pageClass = 'faculty-staff-page';
---

<MainLayout pageClass={pageClass}>
  <Header client:only="react" />
  
  {/* Hero Section */}
  <section style="position: relative; height: 350px; background-image: url(https://images.unsplash.com/photo-1509062522246-3755977927d7?w=1600&q=80); background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center;">
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(11, 42, 111, 0.75);"></div>
    <div style="position: relative; z-index: 10; text-align: center; color: #F7F3EA; max-width: 900px; padding: 0 24px;">
      <h1 style="font-family: var(--heading-font); font-size: 56px; font-weight: 600; margin-bottom: 20px; color: #F7F3EA;">Faculty & Staff</h1>
      <p style="font-family: var(--body-font); font-size: 22px; line-height: 1.6; color: #F7F3EA;">Dedicated educators committed to your child's growth</p>
    </div>
  </section>

  {/* Introduction */}
  <section style="background-color: #F7F3EA; padding: 96px 24px 64px;">
    <div style="max-width: 1000px; margin: 0 auto; text-align: center;">
      <p style="font-family: var(--heading-font); font-size: 24px; color: #26303D; line-height: 1.8; font-style: italic;">
        Our faculty and staff are carefully selected not only for their academic credentials and teaching expertise, but also for their love of Christ, commitment to children, and passion for classical Christian education.
      </p>
    </div>
  </section>

  {/* Leadership */}
  <section style="background-color: #F7F3EA; padding: 0 24px 64px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-family: var(--heading-font); font-size: 42px; color: #123EAB; margin-bottom: 48px; text-align: center; font-weight: 600;">School Leadership</h2>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px;">
        <div style="background-color: #FCFBF7; padding: 40px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 140px; height: 140px; border-radius: 50%; background-color: #123EAB; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 56px; color: #F7F3EA; font-weight: 600;">HN</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 26px; color: #123EAB; margin-bottom: 8px; font-weight: 600;">Headmaster Name</h3>
          <p style="font-family: var(--body-font); font-size: 16px; color: #C8A64E; margin-bottom: 16px; font-weight: 600;">Head of School</p>
          <p style="font-family: var(--body-font); font-size: 16px; color: #26303D; line-height: 1.7;">
            M.Ed. in Educational Leadership, 20+ years in Christian education. Passionate about classical pedagogy and family partnerships.
          </p>
        </div>

        <div style="background-color: #FCFBF7; padding: 40px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 140px; height: 140px; border-radius: 50%; background-color: #123EAB; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 56px; color: #F7F3EA; font-weight: 600;">AD</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 26px; color: #123EAB; margin-bottom: 8px; font-weight: 600;">Academic Director Name</h3>
          <p style="font-family: var(--body-font); font-size: 16px; color: #C8A64E; margin-bottom: 16px; font-weight: 600;">Academic Director</p>
          <p style="font-family: var(--body-font); font-size: 16px; color: #26303D; line-height: 1.7;">
            Ph.D. in Classical Studies, specializing in curriculum development and teacher training in the classical tradition.
          </p>
        </div>

        <div style="background-color: #FCFBF7; padding: 40px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 140px; height: 140px; border-radius: 50%; background-color: #123EAB; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 56px; color: #F7F3EA; font-weight: 600;">ED</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 26px; color: #123EAB; margin-bottom: 8px; font-weight: 600;">Early Childhood Director Name</h3>
          <p style="font-family: var(--body-font); font-size: 16px; color: #C8A64E; margin-bottom: 16px; font-weight: 600;">Early Childhood Director</p>
          <p style="font-family: var(--body-font); font-size: 16px; color: #26303D; line-height: 1.7;">
            AMI Montessori certification, 15+ years guiding young children in hands-on, Christ-centered learning environments.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Faculty */}
  <section style="background-color: #FCFBF7; padding: 96px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-family: var(--heading-font); font-size: 42px; color: #123EAB; margin-bottom: 48px; text-align: center; font-weight: 600;">Our Teaching Faculty</h2>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 32px;">
        {/* Faculty Member 1 */}
        <div style="background-color: #FCFBF7; padding: 32px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background-color: #0B2A6F; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 40px; color: #F7F3EA; font-weight: 600;">SJ</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 22px; color: #123EAB; margin-bottom: 6px; font-weight: 600;">Sarah Johnson</h3>
          <p style="font-family: var(--body-font); font-size: 15px; color: #C8A64E; margin-bottom: 12px; font-weight: 600;">Kindergarten Lead Teacher</p>
          <p style="font-family: var(--body-font); font-size: 15px; color: #26303D; line-height: 1.6;">
            Montessori certified, B.A. in Early Childhood Education
          </p>
        </div>

        {/* Faculty Member 2 */}
        <div style="background-color: #FCFBF7; padding: 32px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background-color: #0B2A6F; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 40px; color: #F7F3EA; font-weight: 600;">MP</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 22px; color: #123EAB; margin-bottom: 6px; font-weight: 600;">Michael Peterson</h3>
          <p style="font-family: var(--body-font); font-size: 15px; color: #C8A64E; margin-bottom: 12px; font-weight: 600;">Grammar Stage (Grades 1-3)</p>
          <p style="font-family: var(--body-font); font-size: 15px; color: #26303D; line-height: 1.6;">
            M.A. in Classical Education, 10 years teaching experience
          </p>
        </div>

        {/* Faculty Member 3 */}
        <div style="background-color: #FCFBF7; padding: 32px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background-color: #0B2A6F; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 40px; color: #F7F3EA; font-weight: 600;">EC</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 22px; color: #123EAB; margin-bottom: 6px; font-weight: 600;">Emily Carter</h3>
          <p style="font-family: var(--body-font); font-size: 15px; color: #C8A64E; margin-bottom: 12px; font-weight: 600;">Logic Stage (Grades 4-6)</p>
          <p style="font-family: var(--body-font); font-size: 15px; color: #26303D; line-height: 1.6;">
            B.A. in Liberal Arts, certified in Classical Christian pedagogy
          </p>
        </div>

        {/* Faculty Member 4 */}
        <div style="background-color: #FCFBF7; padding: 32px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background-color: #0B2A6F; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 40px; color: #F7F3EA; font-weight: 600;">DW</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 22px; color: #123EAB; margin-bottom: 6px; font-weight: 600;">David Williams</h3>
          <p style="font-family: var(--body-font); font-size: 15px; color: #C8A64E; margin-bottom: 12px; font-weight: 600;">Mathematics & Science</p>
          <p style="font-family: var(--body-font); font-size: 15px; color: #26303D; line-height: 1.6;">
            M.S. in Mathematics, passionate about wonder-filled STEM education
          </p>
        </div>

        {/* Faculty Member 5 */}
        <div style="background-color: #FCFBF7; padding: 32px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background-color: #0B2A6F; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 40px; color: #F7F3EA; font-weight: 600;">LM</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 22px; color: #123EAB; margin-bottom: 6px; font-weight: 600;">Laura Martinez</h3>
          <p style="font-family: var(--body-font); font-size: 15px; color: #C8A64E; margin-bottom: 12px; font-weight: 600;">Literature & Humanities</p>
          <p style="font-family: var(--body-font); font-size: 15px; color: #26303D; line-height: 1.6;">
            M.A. in English Literature, loves helping students encounter great books
          </p>
        </div>

        {/* Faculty Member 6 */}
        <div style="background-color: #FCFBF7; padding: 32px; border-radius: 8px; border: 1px solid #D8D2C4; text-align: center;">
          <div style="width: 100px; height: 100px; border-radius: 50%; background-color: #0B2A6F; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--heading-font); font-size: 40px; color: #F7F3EA; font-weight: 600;">RT</span>
          </div>
          <h3 style="font-family: var(--heading-font); font-size: 22px; color: #123EAB; margin-bottom: 6px; font-weight: 600;">Rebecca Taylor</h3>
          <p style="font-family: var(--body-font); font-size: 15px; color: #C8A64E; margin-bottom: 12px; font-weight: 600;">Art & Music</p>
          <p style="font-family: var(--body-font); font-size: 15px; color: #26303D; line-height: 1.6;">
            B.F.A. in Studio Art, dedicated to cultivating creativity and beauty
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Join Our Team */}
  <section style="background-color: #123EAB; padding: 80px 24px; text-align: center;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="font-family: var(--heading-font); font-size: 42px; color: #F7F3EA; margin-bottom: 24px; font-weight: 600;">Join Our Team</h2>
      <p style="font-family: var(--body-font); font-size: 20px; color: #F7F3EA; line-height: 1.7; margin-bottom: 32px;">
        We are always looking for passionate educators who love Christ and desire to serve children and families. If you're interested in joining our faculty, we'd love to hear from you.
      </p>
      <a href="mailto:info@stmarkchristian.school" style="display: inline-block; background-color: #C8A64E; color: #26303D; font-family: var(--button-font); font-size: 18px; font-weight: 600; padding: 16px 40px; border-radius: 6px; text-decoration: none; transition: transform 0.2s;">
        Contact Us About Employment
      </a>
    </div>
  </section>

  <Footer client:only="react" />
</MainLayout>
