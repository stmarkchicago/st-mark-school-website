---
import MainLayout from '../../layouts/main.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer';

const pageClass = 'about-page';
---

<MainLayout pageClass={pageClass}>
  <Header client:only="react" />
  
  {/* Hero Section */}
  <section style="position: relative; height: 400px; background-image: url(https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?w=1600&q=80); background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center;">
    <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(11, 42, 111, 0.75);"></div>
    <div style="position: relative; z-index: 10; text-align: center; color: #F7F3EA; max-width: 900px; padding: 0 24px;">
      <h1 style="font-family: var(--heading-font); font-size: 56px; font-weight: 600; margin-bottom: 20px; color: #F7F3EA;">About St. Mark's</h1>
      <p style="font-family: var(--body-font); font-size: 22px; line-height: 1.6; color: #F7F3EA;">A community dedicated to nurturing young hearts and minds in Christ</p>
    </div>
  </section>

  {/* Mission Section */}
  <section style="background-color: #F7F3EA; padding: 96px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 64px;">
        <h2 style="font-family: var(--heading-font); font-size: 48px; color: #123EAB; margin-bottom: 24px; font-weight: 600;">Our Mission</h2>
        <p style="font-family: var(--heading-font); font-size: 26px; color: #26303D; line-height: 1.7; max-width: 900px; margin: 0 auto; font-style: italic;">
          To provide a Christ-centered education that cultivates wisdom, virtue, and joyful learning in partnership with families, rooted in the Orthodox Christian faith and classical tradition.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; margin-top: 64px;">
        <div style="background-color: #FCFBF7; padding: 40px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <h3 style="font-family: var(--heading-font); font-size: 28px; color: #123EAB; margin-bottom: 16px; font-weight: 600;">Our Vision</h3>
          <p style="font-family: var(--body-font); font-size: 17px; color: #26303D; line-height: 1.8;">
            We envision a community of learners who love God, seek truth, and serve others with joy. Our graduates will be equipped with the knowledge, character, and faith to flourish in life and contribute to the common good.
          </p>
        </div>

        <div style="background-color: #FCFBF7; padding: 40px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <h3 style="font-family: var(--heading-font); font-size: 28px; color: #123EAB; margin-bottom: 16px; font-weight: 600;">Our Values</h3>
          <ul style="font-family: var(--body-font); font-size: 17px; color: #26303D; line-height: 1.8; padding-left: 20px;">
            <li style="margin-bottom: 12px;">Faith-centered education</li>
            <li style="margin-bottom: 12px;">Academic excellence</li>
            <li style="margin-bottom: 12px;">Character formation</li>
            <li style="margin-bottom: 12px;">Family partnership</li>
            <li style="margin-bottom: 12px;">Community service</li>
          </ul>
        </div>

        <div style="background-color: #FCFBF7; padding: 40px; border-radius: 8px; border: 1px solid #D8D2C4;">
          <h3 style="font-family: var(--heading-font); font-size: 28px; color: #123EAB; margin-bottom: 16px; font-weight: 600;">Our History</h3>
          <p style="font-family: var(--body-font); font-size: 17px; color: #26303D; line-height: 1.8;">
            Founded by families seeking a Christ-centered education, St. Mark Christian School has been serving the Burr Ridge community with dedication to Orthodox Christian values and classical learning methods.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Why Choose Section */}
  <section style="background-color: #FCFBF7; padding: 96px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-family: var(--heading-font); font-size: 48px; color: #123EAB; margin-bottom: 48px; text-align: center; font-weight: 600;">Why Choose St. Mark's?</h2>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;">
        <div>
          <div style="height: 400px; background-image: url(https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&q=80); background-size: cover; background-position: center; border-radius: 8px; box-shadow: 0 8px 30px rgba(0,0,0,0.12);"></div>
        </div>
        
        <div>
          <h3 style="font-family: var(--heading-font); font-size: 32px; color: #123EAB; margin-bottom: 20px; font-weight: 600;">A Unique Approach</h3>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8; margin-bottom: 20px;">
            We combine the best of Montessori methods for early childhood with a rigorous classical Christian curriculum for elementary students. This unique approach honors developmental stages while building strong academic foundations.
          </p>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8; margin-bottom: 20px;">
            Our small class sizes ensure personalized attention, and our experienced faculty are committed to knowing each child's unique gifts and challenges.
          </p>
          <p style="font-family: var(--body-font); font-size: 18px; color: #26303D; line-height: 1.8;">
            Most importantly, we see education as a partnership between school and family, with parents as the primary educators of their children.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer client:only="react" />
</MainLayout>
