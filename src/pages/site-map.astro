---
import { baseUrl } from '../lib/base-url';

const pages = [
  { path: '/', name: 'Home' },
  { path: '/about', name: 'About' },
  { path: '/about/statement-of-faith', name: 'Statement of Faith' },
  { path: '/about/faculty-staff', name: 'Faculty & Staff' },
  { path: '/programs', name: 'Programs' },
  { path: '/programs/early-childhood', name: 'Early Childhood' },
  { path: '/programs/elementary', name: 'Elementary' },
  { path: '/admissions', name: 'Admissions' },
  { path: '/admissions/inquire', name: 'Inquire' },
  { path: '/admissions/visit', name: 'Visit' },
  { path: '/admissions/parent-guide', name: 'Parent Guide' },
  { path: '/admissions/apply', name: 'Apply' },
  { path: '/admissions/tuition', name: 'Tuition' },
  { path: '/admissions/faqs', name: 'FAQs' },
  { path: '/faith-formation', name: 'Faith & Formation' },
  { path: '/faith-formation/christian-education', name: 'Christian Education' },
  { path: '/faith-formation/montessori-method', name: 'Montessori Method' },
  { path: '/faith-formation/classical-education', name: 'Classical Education' },
  { path: '/community', name: 'Community' },
  { path: '/community/news', name: 'News' },
  { path: '/community/events', name: 'Events' },
  { path: '/community/testimonials', name: 'Testimonials' },
  { path: '/parent-portal', name: 'Parent Portal' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Site Map - St. Mark School</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      max-width: 800px;
      margin: 40px auto;
      padding: 20px;
      background: #f5f5f5;
    }
    h1 {
      color: #123EAB;
      margin-bottom: 30px;
    }
    .page-list {
      background: white;
      padding: 30px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .page-item {
      padding: 12px 0;
      border-bottom: 1px solid #e0e0e0;
    }
    .page-item:last-child {
      border-bottom: none;
    }
    a {
      color: #123EAB;
      text-decoration: none;
      font-size: 16px;
    }
    a:hover {
      text-decoration: underline;
    }
    .info {
      background: #fff3cd;
      border: 1px solid #ffc107;
      padding: 15px;
      border-radius: 4px;
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <h1>St. Mark School - Site Map</h1>
  
  <div class="info">
    <strong>Base URL:</strong> {baseUrl || '/'}<br/>
    <strong>Total Pages:</strong> {pages.length}
  </div>

  <div class="page-list">
    {pages.map(page => (
      <div class="page-item">
        <a href={`${baseUrl}${page.path}`}>{page.name}</a>
        <span style="color: #888; margin-left: 10px;">({baseUrl}{page.path})</span>
      </div>
    ))}
  </div>
</body>
</html>
